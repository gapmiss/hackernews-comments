{
	"name": "hackernews-comments",
	"version": "1.7.7",
	"description": "An Obsidian.md plugin that scrapes comments from Hacker News posts and creates a markdown note with threaded comments.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"release": "node release.mjs",
		"release:minor": "node release.mjs minor",
		"release:major": "node release.mjs major"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/parser": "^8.60.0",
		"esbuild": "^0.28.1",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"obsidian": "^1.13.1",
		"tslib": "2.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0"
	},
	"allowScripts": {
		"esbuild@0.28.1": true
	}
}
